{"kind":"symbol","sections":[],"metadata":{"extendedModule":"Swift","roleHeading":"Instance Property","symbolKind":"property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","modules":[{"relatedModules":["Swift"],"name":"SwiftExtras"}],"role":"symbol","title":"sdbmhash"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash"},"abstract":[{"type":"text","text":"Hashed string"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library.","type":"text"},{"text":" ","type":"text"},{"text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits.","type":"text"},{"text":" ","type":"text"},{"text":"it also happens to be a good general hashing function with good distribution.","type":"text"},{"text":" ","type":"text"},{"text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];","type":"text"},{"text":" ","type":"text"},{"text":"what is included below is the faster version used in gawk.","type":"text"},{"text":" ","type":"text"},{"text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)","type":"text"},{"text":" ","type":"text"},{"text":"was picked out of thin air while experimenting with many different constants.","type":"text"},{"text":" ","type":"text"},{"text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"]}],"references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","type":"topic","url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash","abstract":[{"type":"text","text":"Hashed string"}],"title":"sdbmhash","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"kind":"symbol","role":"symbol"},"doc://SwiftExtras/documentation/SwiftExtras":{"role":"collection","abstract":[],"type":"topic","url":"\/documentation\/swiftextras","title":"SwiftExtras","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras","kind":"symbol"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","text":"String","preciseIdentifier":"s:SS"}],"type":"topic","abstract":[],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String","title":"String","kind":"symbol","url":"\/documentation\/swiftextras\/swift\/string","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"String"}]},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"type":"topic","title":"Swift","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","url":"\/documentation\/swiftextras\/swift","abstract":[],"role":"collection","kind":"symbol"}}}