{"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library.","type":"text"},{"text":" ","type":"text"},{"text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits.","type":"text"},{"text":" ","type":"text"},{"text":"it also happens to be a good general hashing function with good distribution.","type":"text"},{"text":" ","type":"text"},{"text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];","type":"text"},{"text":" ","type":"text"},{"text":"what is included below is the faster version used in gawk.","type":"text"},{"text":" ","type":"text"},{"text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)","type":"text"},{"text":" ","type":"text"},{"text":"was picked out of thin air while experimenting with many different constants.","type":"text"},{"text":" ","type":"text"},{"text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere.","type":"text"}]}]}],"abstract":[{"text":"Hashed string","type":"text"}],"metadata":{"extendedModule":"Swift","roleHeading":"Instance Property","symbolKind":"property","externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"modules":[{"name":"SwiftExtras","relatedModules":["Swift"]}],"role":"symbol","title":"sdbmhash"},"variants":[{"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","interfaceLanguage":"swift"},"references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","title":"sdbmhash","url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash","abstract":[{"text":"Hashed string","type":"text"}],"role":"symbol","kind":"symbol"},"doc://SwiftExtras/documentation/SwiftExtras":{"role":"collection","title":"SwiftExtras","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras","kind":"symbol","abstract":[],"type":"topic","url":"\/documentation\/swiftextras"},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"url":"\/documentation\/swiftextras\/swift","role":"collection","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","kind":"symbol","abstract":[],"title":"Swift","type":"topic"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"fragments":[{"text":"extension","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"identifier"}],"navigatorTitle":[{"text":"String","kind":"identifier"}],"type":"topic","abstract":[],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftE