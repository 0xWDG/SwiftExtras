{"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"symbol","roleHeading":"Instance Property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","modules":[{"relatedModules":["Swift"],"name":"SwiftExtras"}],"title":"sdbmhash","symbolKind":"property","extendedModule":"Swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"abstract":[{"text":"Hashed string","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library.","type":"text"},{"text":" ","type":"text"},{"text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits.","type":"text"},{"text":" ","type":"text"},{"text":"it also happens to be a good general hashing function with good distribution.","type":"text"},{"text":" ","type":"text"},{"text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];","type":"text"},{"text":" ","type":"text"},{"text":"what is included below is the faster version used in gawk.","type":"text"},{"text":" ","type":"text"},{"text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)","type":"text"},{"text":" ","type":"text"},{"text":"was picked out of thin air while experimenting with many different constants.","type":"text"},{"text":" ","type":"text"},{"text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://SwiftExtras/documentation/SwiftExtras":{"title":"SwiftExtras","type":"topic","abstract":[],"kind":"symbol","role":"collection","url":"\/documentation\/swiftextras","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"abstract":[{"text":"Hashed string","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"kind":"symbol","url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","type":"topic","title":"sdbmhash","role":"symbol"},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"abstract":[],"kind":"symbol","url":"\/documentation\/swiftextras\/swift","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","type":"topic","title":"Swift","role":"collection"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"abstract":[],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String","navigatorTitle":[{"kind":"identifier","text":"String"}],"fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"preciseIdentifier":"s:SS","kind":"identifier","text":"Str