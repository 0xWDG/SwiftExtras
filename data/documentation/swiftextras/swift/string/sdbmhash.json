{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Hashed string","type":"text"}],"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library."},{"type":"text","text":" "},{"type":"text","text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits."},{"type":"text","text":" "},{"type":"text","text":"it also happens to be a good general hashing function with good distribution."},{"type":"text","text":" "},{"type":"text","text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];"},{"type":"text","text":" "},{"type":"text","text":"what is included below is the faster version used in gawk."},{"type":"text","text":" "},{"type":"text","text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)"},{"type":"text","text":" "},{"type":"text","text":"was picked out of thin air while experimenting with many different constants."},{"type":"text","text":" "},{"type":"text","text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"extendedModule":"Swift","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"modules":[{"name":"SwiftExtras","relatedModules":["Swift"]}],"externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","role":"symbol","symbolKind":"property","roleHeading":"Instance Property","title":"sdbmhash"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"]}],"references":{"doc://SwiftExtras/documentation/SwiftExtras":{"type":"topic","abstract":[],"role":"collection","title":"SwiftExtras","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras","url":"\/documentation\/swiftextras","kind":"symbol"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"role":"symbol","fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","preciseIdentifier":"s:SS","text":"String"}],"title":"String","abstract":[],"navigatorTitle":[{"kind":"identifier","text":"String"}],"kind":"symbol","url":"\/documentation\/swiftextras\/swift\/string","type":"topic","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"kind":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","role":"collection","type":"topic","url":"\/documentation\/swiftextras\/swift","abstract":[],"title":"Swift"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash","kind":"symbol","title":"sdbmhash","role":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"text":"In