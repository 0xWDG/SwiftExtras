{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library."},{"type":"text","text":" "},{"type":"text","text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits."},{"type":"text","text":" "},{"type":"text","text":"it also happens to be a good general hashing function with good distribution."},{"type":"text","text":" "},{"type":"text","text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];"},{"type":"text","text":" "},{"type":"text","text":"what is included below is the faster version used in gawk."},{"type":"text","text":" "},{"type":"text","text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)"},{"type":"text","text":" "},{"type":"text","text":"was picked out of thin air while experimenting with many different constants."},{"type":"text","text":" "},{"type":"text","text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere."}]}],"kind":"content"}],"variants"