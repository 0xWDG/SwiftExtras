{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"]}],"abstract":[{"type":"text","text":"Hashed string"}],"kind":"symbol","metadata":{"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"title":"sdbmhash","extendedModule":"Swift","externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","symbolKind":"property","roleHeading":"Instance Property","modules":[{"relatedModules":["Swift"],"name":"SwiftExtras"}]},"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library.","type":"text"},{"text":" ","type":"text"},{"text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits.","type":"text"},{"text":" ","type":"text"},{"text":"it also happens to be a good general hashing function with good distribution.","type":"text"},{"text":" ","type":"text"},{"text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];","type":"text"},{"text":" ","type":"text"},{"text":"what is included below is the faster version used in gawk.","type":"text"},{"text":" ","type":"text"},{"text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)","type":"text"},{"text":" ","type":"text"},{"text":"was picked out of thin air while experimenting with many different constants.","type":"text"},{"text":" ","type":"text"},{"text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","interfaceLanguage":"swift"},"references":{"doc://SwiftExtras/documentation/SwiftExtras":{"url":"\/documentation\/swiftextras","title":"SwiftExtras","role":"collection","type":"topic","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras","abstract":[],"kind":"symbol"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"type":"topic","title":"sdbmhash","abstract":[{"type":"text","text":"Hashed string"}],"url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash"},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"title":"Swift","url":"\/documentation\/swiftextras\/swift","role":"collection","type":"topic","abstract":[],"kind":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"String"}],"fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","preciseIdentifier":"s:SS","text":"String"}],"abstract":[],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String","url":"\/documentation\/swiftextras\/swift\/string","kind":"symbol","title":"String","role":"symbol"}}}