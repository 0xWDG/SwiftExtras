{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library.","type":"text"},{"text":" ","type":"text"},{"text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits.","type":"text"},{"text":" ","type":"text"},{"text":"it also happens to be a good general hashing function with good distribution.","type":"text"},{"text":" ","type":"text"},{"text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];","type":"text"},{"text":" ","type":"text"},{"text":"what is included below is the faster version used in gawk.","type":"text"},{"text":" ","type":"text"},{"text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)","type":"text"},{"text":" ","type":"text"},{"text":"was picked out of thin air while experimenting with many different constants.","type":"text"},{"text":" ","type":"text"},{"text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifi