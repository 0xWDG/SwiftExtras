{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"metadata":{"modules":[{"relatedModules":["Swift"],"name":"SwiftExtras"}],"role":"symbol","symbolKind":"property","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"roleHeading":"Instance Property","extendedModule":"Swift","title":"sdbmhash","externalID":"s:SS11SwiftExtrasE8sdbmhashSivp"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library.","type":"text"},{"text":" ","type":"text"},{"text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits.","type":"text"},{"text":" ","type":"text"},{"text":"it also happens to be a good general hashing function with good distribution.","type":"text"},{"text":" ","type":"text"},{"text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];","type":"text"},{"text":" ","type":"text"},{"text":"what is included below is the faster version used in gawk.","type":"text"},{"text":" ","type":"text"},{"text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)","type":"text"},{"text":" ","type":"text"},{"text":"was picked out of thin air while experimenting with many different constants.","type":"text"},{"text":" ","type":"text"},{"text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Hashed string"}],"references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"url":"\/documentation\/swiftextras\/swift\/string","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String","title":"String","kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","text":"String","preciseIdentifier":"s:SS"}],"navigatorTitle":[{"kind":"identifier","text":"String"}],"abstract":[]},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"type":"topic","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","kind":"symbol","url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"abstract":[{"text":"Hashed string","type":"text"}],"role":"symbol","title":"sdbmhash"},"doc://SwiftExtras/documentation/SwiftExtras":{"title":"SwiftExtras","role":"collection","url":"\/documentation\/swiftextras","kind":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras","type":"topic","abstract":[]},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","u