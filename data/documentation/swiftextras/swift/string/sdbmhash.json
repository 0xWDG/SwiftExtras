{"abstract":[{"type":"text","text":"Hashed string"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash"},"variants":[{"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"property","externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","title":"sdbmhash","roleHeading":"Instance Property","extendedModule":"Swift","modules":[{"relatedModules":["Swift"],"name":"SwiftExtras"}],"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]},"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library.","type":"text"},{"text":" ","type":"text"},{"text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits.","type":"text"},{"text":" ","type":"text"},{"text":"it also happens to be a good general hashing function with good distribution.","type":"text"},{"text":" ","type":"text"},{"text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];","type":"text"},{"text":" ","type":"text"},{"text":"what is included below is the faster version used in gawk.","type":"text"},{"text":" ","type":"text"},{"text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)","type":"text"},{"text":" ","type":"text"},{"text":"was picked out of thin air while experimenting with many different constants.","type":"text"},{"text":" ","type":"text"},{"text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere.","type":"text"}]}]}],"references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash","role":"symbol","title":"sdbmhash","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","abstract":[{"text":"Hashed string","type":"text"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"role":"symbol","fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","preciseIdentifier":"s:SS","text":"String"}],"navigatorTitle":[{"kind":"identifier","text":"String"}],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String","title":"String","kind":"symbol","url":"\/documentation\/swiftextras\/swift\/string","abstract":[],"type":"topic"},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"abstract":[],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","role":"collection","url":"\/documentation\/swiftextras\/swift","type":"topic","kind":"symbol","title":"Swift"},"doc://SwiftExtras/documentation/SwiftExtras":{"role":"collection","identifier":"doc:\/\/SwiftExtras\/documenta