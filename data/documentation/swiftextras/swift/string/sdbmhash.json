{"kind":"symbol","abstract":[{"text":"Hashed string","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library."},{"type":"text","text":" "},{"type":"text","text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits."},{"type":"text","text":" "},{"type":"text","text":"it also happens to be a good general hashing function with good distribution."},{"type":"text","text":" "},{"type":"text","text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];"},{"type":"text","text":" "},{"type":"text","text":"what is included below is the faster version used in gawk."},{"type":"text","text":" "},{"type":"text","text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)"},{"type":"text","text":" "},{"type":"text","text":"was picked out of thin air while experimenting with many different constants."},{"type":"text","text":" "},{"type":"text","text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere."}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"]}],"metadata":{"roleHeading":"Instance Property","role":"symbol","modules":[{"name":"SwiftExtras","relatedModules":["Swift"]}],"symbolKind":"property","externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","extendedModule":"Swift","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"title":"sdbmhash"},"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","interfaceLanguage":"swift"},"references":{"doc://SwiftExtras/documentation/SwiftExtras":{"role":"collection","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras","url":"\/documentation\/swiftextras","type":"topic","abstract":[],"kind":"symbol","title":"SwiftExtras"},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"kind":"symbol","abstract":[],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","type":"topic","url":"\/documentation\/swiftextras\/swift","title":"Swift","role":"collection"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"kind":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","role":"symbol","url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash","type":"topic","title":"sdbmhash","abstract":[{"type":"text","text":"Hashed string"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","text":"String","preciseIdentifier":"s:SS"}],"navigatorTitle":[{"kind":"identifier","text":"String"}],"type":"topic","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/