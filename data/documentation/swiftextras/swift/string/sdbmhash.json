{"abstract":[{"type":"text","text":"Hashed string"}],"kind":"symbol","variants":[{"paths":["\/documentation\/swiftextras\/swift\/string\/sdbmhash"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"roleHeading":"Instance Property","externalID":"s:SS11SwiftExtrasE8sdbmhashSivp","symbolKind":"property","extendedModule":"Swift","title":"sdbmhash","role":"symbol","modules":[{"name":"SwiftExtras","relatedModules":["Swift"]}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sdbmhash","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This algorithm was created for sdbm (a public-domain reimplementation of ndbm) database library."},{"type":"text","text":" "},{"type":"text","text":"it was found to do well in scrambling bits, causing better distribution of the keys and fewer splits."},{"type":"text","text":" "},{"type":"text","text":"it also happens to be a good general hashing function with good distribution."},{"type":"text","text":" "},{"type":"text","text":"the actual function is hash(i) = hash(i - 1) * 65599 + str[i];"},{"type":"text","text":" "},{"type":"text","text":"what is included below is the faster version used in gawk."},{"type":"text","text":" "},{"type":"text","text":"[there is even a faster, duff-device version] the magic prime constant 65599 (2^6 + 2^16 - 1)"},{"type":"text","text":" "},{"type":"text","text":"was picked out of thin air while experimenting with many different constants."},{"type":"text","text":" "},{"type":"text","text":"this is one of the algorithms used in berkeley db (see sleepycat) and elsewhere."}]}]}],"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String"]]},"references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"url":"\/documentation\/swiftextras\/swift","kind":"symbol","title":"Swift","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","type":"topic","abstract":[],"role":"collection"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String/sdbmhash":{"type":"topic","kind":"symbol","title":"sdbmhash","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdbmhash"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/String\/sdbmhash","abstract":[{"type":"text","text":"Hashed string"}],"role":"symbol","url":"\/documentation\/swiftextras\/swift\/string\/sdbmhash"},"doc://SwiftExtras/documentation/SwiftExtras":{"url":"\/documentation\/swiftextras","kind":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras","type":"topic","abstract":[],"role":"collection","title":"SwiftExtras"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/String":{"fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","preciseIdentifier":"s:SS","text":"String"}],"navigatorTitle":[{"kind":"identifier","text":"String"}],"url":"\/documentation\/swiftextras\/swift\/string","type":"topic","role":"symbol","k