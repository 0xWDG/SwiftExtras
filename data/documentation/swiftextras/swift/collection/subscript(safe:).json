S"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The position of the element to access.","type":"text"},{"text":" ","type":"text"},{"text":"If the index is within the bounds of the collection, ","type":"text"},{"text":"\n","type":"text"},{"text":"the element at that position is returned. Otherwise, ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" is returned.","type":"text"}]}],"name":"index"}],"kind":"parameters"},{"content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The element at the specified index if it is within the collection’s bounds; otherwise, "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}],"kind":"content"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This subscript provides a safe way to access elements within the collection by"},{"type":"text","text":" "},{"type":"text","text":"returning "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" instead of crashing when accessing an index out of bounds."},{"type":"text","text":" "},{"type":"text","text":"It is useful for avoiding runtime errors when the exact count of the collection"},{"type":"text","text":" "},{"type":"text","text":"might not be known or when dealing with dynamic data sources."},{"type":"text","text":" "},{"type":"text","text":"This approach ensures that attempts to access indices outside the valid"},{"type":"text","text":" "},{"type":"text","text":"range simply result in "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", allowing for more graceful handling of such cases."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example usage:"}]},{"type":"codeListing","syntax":null,"code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"]},{"type":"paragraph","inlineContent":[{"text":"This method enhances the safety and readability of collection access, ","type":"text"},{"text":"\n","type":"text"},{"text":"especially in more complex logic where bounds checks are necessary.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftextras\/swift\/collection\/subscript(safe:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection\/subscript(safe:)"},"kind":"symbol","abstract":[{"text":"Accesses the element at the specified position in a safe manner.","type":"text"}],"references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift/Collection/subscript(safe:)":{"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection\/subscript(safe:)","kind":"symbol","abstract":[{"text":"Accesses the element at the specified position in a safe manner.","type":"text"}],"role":"symbol","conformance":{"conformancePrefix":[{"text":"Conforms when","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}],"constraints":[{"code":"Self","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"Collection","type":"codeVoice"},{"text":".","type":"text"}]},"url":"\/documentation\/swiftextras\/swift\/collection\/subscript(safe:)","fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"("},{"kind":"externalParam","text":"safe"},{"kind":"text","text":" _: "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"preciseIdentifier":"s:Sl5IndexQa","kind":"typeIdentifier","text":"Index"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"preciseIde