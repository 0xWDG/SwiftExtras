unds of the collection, ","type":"text"},{"text":"\n","type":"text"},{"text":"the element at that position is returned. Otherwise, ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" is returned.","type":"text"}]}],"name":"index"}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The element at the specified index if it is within the collection’s bounds; otherwise, "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"This subscript provides a safe way to access elements within the collection by","type":"text"},{"text":" ","type":"text"},{"text":"returning ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" instead of crashing when accessing an index out of bounds.","type":"text"},{"text":" ","type":"text"},{"text":"It is useful for avoiding runtime errors when the exact count of the collection","type":"text"},{"text":" ","type":"text"},{"text":"might not be known or when dealing with dynamic data sources.","type":"text"},{"text":" ","type":"text"},{"text":"This approach ensures that attempts to access indices outside the valid","type":"text"},{"text":" ","type":"text"},{"text":"range simply result in ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", allowing for more graceful handling of such cases.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Example usage:","type":"text"}]},{"type":"codeListing","syntax":null,"code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"]},{"typ