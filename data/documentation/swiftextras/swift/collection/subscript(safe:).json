to access elements within the collection by"},{"type":"text","text":" "},{"type":"text","text":"returning "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" instead of crashing when accessing an index out of bounds."},{"type":"text","text":" "},{"type":"text","text":"It is useful for avoiding runtime errors when the exact count of the collection"},{"type":"text","text":" "},{"type":"text","text":"might not be known or when dealing with dynamic data sources."},{"type":"text","text":" "},{"type":"text","text":"This approach ensures that attempts to access indices outside the valid"},{"type":"text","text":" "},{"type":"text","text":"range simply result in "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", allowing for more graceful handling of such cases."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example usage:"}]},{"type":"codeListing","code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method enhances the safety and readability of collection access, "},{"type":"text","text":"\n"},{"type":"text","text":"especially in more complex logic where bounds checks are necessary."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swiftextras\/swift\/collection\/subscript(safe:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection"]]},"metadata":{"title":"subscript(safe:)","fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"("},{"kind":"externalParam","tex