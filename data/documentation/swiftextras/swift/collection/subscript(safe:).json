s."}],"type":"paragraph"},{"inlineContent":[{"text":"Example usage:","type":"text"}],"type":"paragraph"},{"code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"This method enhances the safety and readability of collection access, ","type":"text"},{"text":"\n","type":"text"},{"text":"especially in more complex logic where bounds checks are necessary.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Accesses the element at the specified position in a safe manner.","type":"text"}],"kind":"symbol","references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","url":"\/documentation\/swiftextras\/swift","kind":"symbol","role":"collection","type":"topic","abstract":[],"title":"Swift"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/Collection":{"abstract":[],"role":"symbol","fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"preciseIdentifier":"s:Sl","kind":"identifier","text":"Collection"}],"navigatorTitle":[{"kind":"identifier","text":"Collection"}],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection","kind":"symbol","url":"\/documentation\/swiftextras\/swift\/collection","type":"topic","title":"Collection"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/Collection/subscript(safe:)":{"kind":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection\/subscript(safe:)","role":"symbol","fragments":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"safe","kind":"externalParam"},{"text