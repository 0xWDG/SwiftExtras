ind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:Sl5IndexQa"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:ST7ElementQa"},{"kind":"text","text":"? { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]},{"parameters":[{"name":"index","content":[{"type":"paragraph","inlineContent":[{"text":"The position of the element to access.","type":"text"},{"text":" ","type":"text"},{"text":"If the index is within the bounds of the collection, ","type":"text"},{"text":"\n","type":"text"},{"text":"the element at that position is returned. Otherwise, ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" is returned.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"The element at the specified index if it is within the collection’s bounds; otherwise, ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]}]},{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"This subscript provides a safe way to access elements within the collection by"},{"type":"text","text":" "},{"type":"text","text":"returning "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" instead of crashing when accessing an index out of bounds."},{"type":"text","text":" "},{"type":"text","text":"It is useful for avoiding runtime errors when the exact count of the collection"},{"type":"text","text":" "},{"type":"text","text":"might not be known or when dealing with dynamic data sources."},{"type":"text","text":" "},{"type":"text","text":"This approach ensures that attempts to access indices outside the valid"},{"type":"text","text":" "},{"type":"text","text":"range simply result in "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", allowing for more graceful handling of such cases."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example usage:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"]},{"inlineContent":[{"type":"text","text":"This method enhances the safety and readability of collection access, "},{"type":"text","text":"\n"},{"type":"text","text":"especially in more complex logic where bounds checks are necessary."}],"type":"paragraph"}]}],"references":{"doc://SwiftExtras/documentation/SwiftExtras":{"title":"SwiftExtras","role":"collection","abstract":[],"type":"topic","url":"\/documentation\/swiftextras","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras","kind":"symbol"},"doc://SwiftExtras/documentation/SwiftExtras/Swift":{"type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","abstract":[],"url":"\/documentation\/swiftextras\/swift","title":"Swift"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/Collection":{"kind":"symbol","fragments":[{"text":"extension","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Collection","preciseIdentifier":"s:Sl","kind":"identifier"}],"identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection","abstract":[],"title":"Collection","role":"symbol","type":"topic","navigatorTitle":[{"text":"Collection","kind":"identifier"}],"url":"\/documentation\/swiftextras\/swift\/collection"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/Collection/subscript(safe:)":{"abstract":[{"type":