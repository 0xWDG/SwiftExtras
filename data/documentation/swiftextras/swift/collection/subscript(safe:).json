ew"},{"type":"paragraph","inlineContent":[{"text":"This subscript provides a safe way to access elements within the collection by","type":"text"},{"text":" ","type":"text"},{"text":"returning ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" instead of crashing when accessing an index out of bounds.","type":"text"},{"text":" ","type":"text"},{"text":"It is useful for avoiding runtime errors when the exact count of the collection","type":"text"},{"text":" ","type":"text"},{"text":"might not be known or when dealing with dynamic data sources.","type":"text"},{"text":" ","type":"text"},{"text":"This approach ensures that attempts to access indices outside the valid","type":"text"},{"text":" ","type":"text"},{"text":"range simply result in ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", allowing for more graceful handling of such cases.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Example usage:","type":"text"}]},{"type":"codeListing","code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method enhances the safety and readability of collection access, "},{"type":"text","text":"\n"},{"type":"text","text":"especially in more complex logic where bounds checks are necessary."}]}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection\/subscript(safe:)"},"abstract":[{"type":"text","text":"Accesses the element at the specified position in a safe manner."}],"metadata":{"fragments":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"safe","kind":"externalParam"},{"text":" _: ","