ype":"text"},{"text":"range simply result in ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", allowing for more graceful handling of such cases.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example usage:"}]},{"type":"codeListing","syntax":null,"code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"]},{"type":"paragraph","inlineContent":[{"text":"This method enhances the safety and readability of collection access, ","type":"text"},{"text":"\n","type":"text"},{"text":"especially in more complex logic where bounds checks are necessary.","type":"text"}]}],"kind":"content"}],"references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift/Collection/subscript(safe:)":{"type":"topic","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection\/subscript(safe:)","fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"("},{"kind":"externalParam","text":"safe"},{"kind":"text","text":" _: "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:Sl5IndexQa"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:ST7ElementQa"},{"kind":"text","text":"?"}],"abstract":[{"type":"text","text":"Accesses the element at the specified position in a safe manner."}],"kind":"symbol","title":"subscript(safe:)","conformance":{"constraints":[{"code":"Self","type":"codeVoice"},{"type":"text","text":" is "},{"code":"Collection","type":"codeVoice"},{"type":"text","text":"."}],"conformancePrefix":[{"type":"text","text":"Conforms when"}],"availabilityPre