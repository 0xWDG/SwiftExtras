{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Accesses the element at the specified position in a safe manner."}],"hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"safe","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"index","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Index","preciseIdentifier":"s:Sl5IndexQa","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:ST7ElementQa","text":"Element","kind":"typeIdentifier"},{"text":"? { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The position of the element to access."},{"type":"text","text":" "},{"type":"text","text":"If the index is within the bounds of the collection, "},{"type":"text","text":"\n"},{"type":"text","text":"the element at that position is returned. Otherwise, "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned."}]}],"name":"index"}],"kind":"parameters"},{"content":[{"level":2,"anchor":"return-value","text":"Return Value","type":"heading"},{"inlineContent":[{"type":"text","text":"The element at the specified index if it is within the collection’s bounds; otherwise, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This subscript provides a safe way to access elements within the collection by","type":"text"},{"text":" ","type":"text"},{"text":"returning ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" instead of crashing when accessing an index out of bounds.","type":"text"},{"text":" ","type":"text"},{"text":"It is useful for avoiding runtime errors when the exact count of the collection","type":"text"},{"text":" ","type":"text"},{"text":"might not be known or when dealing with dynamic data sources.","type":"text"},{"text":" ","type":"text"},{"text":"This approach ensures that attempts to access indices outside the valid","type":"text"},{"text":" ","type":"text"},{"text":"range simply result in ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", allowing for more graceful handling of such cases.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example usage:"}]},{"type":"codeListing","syntax":null,"code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method enhances the safety and readability of collection access, "},{"type":"text","text":"\n"},{"type":"text","text":"especially in more complex logic where bounds checks are necessary."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection\/subscript(safe:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/swiftextras\/swift\/collection\/subscript(safe:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"SwiftExtras","relatedModules":["Swift"]}],"roleHeading":"Instance Subscript","conformance":{"constraints":[{"code":"Self","type":"codeVoice"},{