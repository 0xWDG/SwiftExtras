content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This subscript provides a safe way to access elements within the collection by"},{"text":" ","type":"text"},{"text":"returning ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" instead of crashing when accessing an index out of bounds."},{"type":"text","text":" "},{"type":"text","text":"It is useful for avoiding runtime errors when the exact count of the collection"},{"text":" ","type":"text"},{"text":"might not be known or when dealing with dynamic data sources.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This approach ensures that attempts to access indices outside the valid"},{"text":" ","type":"text"},{"type":"text","text":"range simply result in "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", allowing for more graceful handling of such cases."}]},{"inlineContent":[{"type":"text","text":"Example usage:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method enhances the safety and readability of collection access, "},{"type":"text","text":"\n"},{"type":"text","text":"especially in more complex logic where bounds checks are necessary."}]}],"kind":"content"}],"metadata":{"role":"symbol","title":"subscript(safe:)","externalID":"s:Sl11SwiftExtrasE4safe7ElementQzSg5IndexQz_tcip","fragments":[{"kind":"keyword","text":"subscript"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"safe"},{"text":" _: ","kind":"text"},{"kind":"typeIdentifier","text":"Self"},{"t