{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"("},{"kind":"externalParam","text":"safe"},{"kind":"text","text":" "},{"kind":"internalParam","text":"index"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa","text":"Index"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa","text":"Element"},{"kind":"text","text":"? { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"index","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The position of the element to access."},{"type":"text","text":" "},{"type":"text","text":"If the index is within the bounds of the collection, "},{"type":"text","text":"\n"},{"type":"text","text":"the element at that position is returned. Otherwise, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned."}]}]}],"kind":"parameters"},{"content":[{"text":"Return Value","type":"heading","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The element at the specified index if it is within the collection’s bounds; otherwise, "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}],"kind":"content"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"This subscript provides a safe way to access elements within the collection by","type":"text"},{"text":" ","type":"text"},{"text":"returning ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" instead of crashing when accessing an index out of bounds.","type":"text"},{"text":" ","type":"text"},{"text":"It is useful for avoiding runtime errors when the exact count of the collection","type":"text"},{"text":" ","type":"text"},{"text":"might not be known or when dealing with dynamic data sources.","type":"text"},{"text":" ","type":"text"},{"text":"This approach ensures that attempts to access indices outside the valid","type":"text"},{"text":" ","type":"text"},{"text":"range simply result in ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", allowing for more graceful handling of such cases.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example usage:"}]},{"type":"codeListing","code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"This method enhances the safety and readability of collection access, ","type":"text"},{"text":"\n","type":"text"},{"text":"especially in more complex logic where bounds checks are necessary.","type":"text"}]}],"kind":"content"}],"metadata":{"extendedModule":"Swift","title":"subscript(safe:)","symbolKind":"subscript","fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"("},{"kind":"externalParam","text":"safe"},{"kind":"text","text":" _: "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa","text":"Index"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa","text":"Element"},{"kind":"text","text":"?"}],"role":"symbol","conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"type":"codeVoice","code":"Self"},{"type":"text","text":" is "},{"type":"codeVoice","code":"Collection"},