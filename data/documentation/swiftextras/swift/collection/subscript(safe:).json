":"text","text":"range simply result in "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", allowing for more graceful handling of such cases."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example usage:"}],"type":"paragraph"},{"syntax":null,"code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"],"type":"codeListing"},{"inlineContent":[{"text":"This method enhances the safety and readability of collection access, ","type":"text"},{"text":"\n","type":"text"},{"text":"especially in more complex logic where bounds checks are necessary.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://SwiftExtras/documentation/SwiftExtras/Swift/Collection":{"navigatorTitle":[{"text":"Collection","kind":"identifier"}],"type":"topic","role":"symbol","fragments":[{"text":"extension","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:Sl","text":"Collection","kind":"identifier"}],"abstract":[],"url":"\/documentation\/swiftextras\/swift\/collection","kind":"symbol","title":"Collection","identifier":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection"},"doc://SwiftExtras/documentation/SwiftExtras/Swift/Collection/subscript(safe:)":{"url":"\/documentation\/swiftextras\/swift\/collection\/subscript(safe:)","role":"symbol","fragments":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"safe","kind":"externalParam"},{"text":" _: ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sl5IndexQa","text":"Index","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:ST