ontent":[{"text":"This subscript provides a safe way to access elements within the collection by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returning "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" instead of crashing when accessing an index out of bounds."},{"text":" ","type":"text"},{"text":"It is useful for avoiding runtime errors when the exact count of the collection","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"might not be known or when dealing with dynamic data sources."},{"text":" ","type":"text"},{"type":"text","text":"This approach ensures that attempts to access indices outside the valid"},{"type":"text","text":" "},{"text":"range simply result in ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", allowing for more graceful handling of such cases."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example usage:"}]},{"type":"codeListing","code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"],"syntax":null},{"inlineContent":[{"type":"text","text":"This method enhances the safety and readability of collection access, "},{"type":"text","text":"\n"},{"type":"text","text":"especially in more complex logic where bounds checks are necessary."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Accesses the element at the specified position in a safe manner.","type":"text"}],"identifier":{"url":"doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection\/subscript(safe:)","interfaceLanguage":"swift"},"sections":[],"metadata":{"modules":[{"relatedModules":["Swift"],"name":"SwiftExtras"}],"role":"symbol","roleHeading":"Instance Subscript","symbolKind":"subscript","extendedMo