{"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftExtras\/documentation\/SwiftExtras","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift","doc:\/\/SwiftExtras\/documentation\/SwiftExtras\/Swift\/Collection"]]},"abstract":[{"text":"Accesses the element at the specified position in a safe manner.","type":"text"}],"variants":[{"paths":["\/documentation\/swiftextras\/swift\/collection\/subscript(safe:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"safe","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"index","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Index","kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:ST7ElementQa"},{"text":"? { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The position of the element to access."},{"type":"text","text":" "},{"type":"text","text":"If the index is within the bounds of the collection, "},{"type":"text","text":"\n"},{"type":"text","text":"the element at that position is returned. Otherwise, "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned."}],"type":"paragraph"}],"name":"index"}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The element at the specified index if it is within the collection’s bounds; otherwise, "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This subscript provides a safe way to access elements within the collection by"},{"type":"text","text":" "},{"type":"text","text":"returning "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" instead of crashing when accessing an index out of bounds."},{"type":"text","text":" "},{"type":"text","text":"It is useful for avoiding runtime errors when the exact count of the collection"},{"type":"text","text":" "},{"type":"text","text":"might not be known or when dealing with dynamic data sources."},{"type":"text","text":" "},{"type":"text","text":"This approach ensures that attempts to access indices outside the valid"},{"type":"text","text":" "},{"type":"text","text":"range simply result in "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", allowing for more graceful handling of such cases."}],"type":"paragraph"},{"inlineContent":[{"text":"Example usage:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["let numbers = [1, 2, 3, 4, 5]","if let number = numbers[safe: 3] {","    print(number) \/\/ Prints \"4\"","} else {","    print(\"Index out of bounds\")","}","","if let outOfBoundsNumber = numbers[safe: 10] {","    print(outOfBoundsNumber)","} else {","    print(\"Index out of bounds\") \/\/ Prints \"Index out of bounds\"","}"]},{"inlineContent":[{"text":"This method enhances the safety and readability of collection access, ","type":"text"},{"text":"\n","type":"text"},{"text":"especially in more complex logic where bounds checks are necessary.","type":"text"}],"type":"paragraph"}]}],"sections":[],"metadata":{"symbolKind":"subscript","extendedModule":"Swift","conformance":{"conformancePrefix":[{"text":"Conforms when","type":"text"}],"constraints":[{"type":"codeVoice","code":"Self"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"Collection"},{"text":".","type":"te